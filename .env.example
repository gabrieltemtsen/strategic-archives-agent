# =============================================
# STRATEGIC ARCHIVES AGENT - ENV CONFIG
# =============================================

# --- Google / Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID must be your NUMERIC user ID — get it from @userinfobot
TELEGRAM_CHAT_ID=123456789

# --- Hugging Face ---
HUGGINGFACE_API_TOKEN=your_huggingface_token

# --- Channels ---
# All 4 channels defined here. No code changes needed to add/remove channels.
# youtube_id: YouTube Studio → Settings → Advanced settings → Channel ID
CHANNELS=[{"key":"kids_universe","name":"KidsFirstUniverse","youtube_id":"UCVDXMW5JbIl8_FoTOkmCR-g","niche":"kids content - educational stories, fun facts, nursery rhymes, and entertaining videos for children aged 2-10. Warm, fun, engaging tone.","upload_time":"18:00","made_for_kids":true,"emoji":"🧒","languages":["en","yo","ha"]},{"key":"strategic_archives","name":"StrategicArchives","youtube_id":"UCfX3YMbTv6lWaU983F-GCDA","niche":"war history - gripping accounts of military battles, combat strategies, sieges, and geopolitical conflicts from ancient times to modern warfare. Dramatic, cinematic narration.","upload_time":"17:00","made_for_kids":false,"emoji":"⚔️","languages":["en"]},{"key":"stories_tales","name":"yt-storiesandtales","youtube_id":"UCxxxxxxxxxxxxxxxxxx","niche":"scary stories and creepy tales - spine-chilling horror stories, eerie urban legends, shocking true crime, and dramatic health facts that will keep you up at night.","upload_time":"20:00","made_for_kids":false,"emoji":"👻","languages":["en"]},{"key":"gabe_dev_codes","name":"gabedevcodes","youtube_id":"UCxxxxxxxxxxxxxxxxxx","niche":"coding tutorials and AI development - practical programming guides, how to build and leverage AI tools, developer tips, and real projects that generate income.","upload_time":"16:00","made_for_kids":false,"emoji":"💻","languages":["en"]}]

# --- YouTube OAuth Client Secret ---
# Download from Google Cloud Console → APIs & Services → Credentials
# Encode: base64 -i client_secret.json | tr -d '\n'
YOUTUBE_CLIENT_SECRET_B64=

# --- Per-Channel YouTube Tokens (REQUIRED — one per channel) ---
# Generate with: python scripts/auth_channel.py --channel <key>
# IMPORTANT: Switch to the correct channel in YouTube Studio BEFORE running!
# Encode: base64 -i .youtube_token_kids_universe.pkl | tr -d '\n'

YOUTUBE_TOKEN_B64_KIDS_UNIVERSE=
YOUTUBE_TOKEN_B64_STRATEGIC_ARCHIVES=
YOUTUBE_TOKEN_B64_STORIES_TALES=
YOUTUBE_TOKEN_B64_GABE_DEV_CODES=

# Legacy single-channel fallback (uploads to default channel — avoid using)
# YOUTUBE_TOKEN_B64=

# --- App ---
LOG_LEVEL=INFO
OUTPUT_DIR=./output
ASSETS_DIR=./assets

# --- Railway ---
# PORT is auto-injected by Railway — do not set manually
# Railway Volume: mount at /app/data for SQLite (jobs.db)
