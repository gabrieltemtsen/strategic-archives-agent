# =============================================
# STRATEGIC ARCHIVES AGENT - ENV CONFIG
# =============================================
# Copy this to .env and fill in your values

# --- Google / Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_TTS_API_KEY=your_google_cloud_api_key_here   # Or use service account JSON below
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json  # For Google Cloud TTS

# --- Channels ---
# All channel config lives here — JSON array, one env var, done.
# Add/remove channels by editing this. No code or config.yaml changes needed.
# Fields per channel:
#   key          - unique identifier (lowercase, underscores)
#   name         - display name
#   youtube_id   - YouTube channel ID (from YouTube Studio → Settings → Advanced)
#   niche        - free text description — the agent uses this to generate content
#   upload_time  - daily upload time in WAT (HH:MM)
#   made_for_kids - true/false (YouTube requirement)
#   emoji        - shown in Telegram picker
#   languages    - list of language codes to rotate through (optional)
CHANNELS=[{"key":"kids_universe","name":"KidsUniverseFirst","youtube_id":"UCxxxxxxxxxxxxxxxxxx","niche":"kids education - soothing bedtime stories and fun facts for children aged 3-10","upload_time":"18:00","made_for_kids":true,"emoji":"🧒","languages":["en","fr","yo"]},{"key":"strategic_archives","name":"StrategicArchives","youtube_id":"UCxxxxxxxxxxxxxxxxxx","niche":"TBD","upload_time":"17:00","emoji":"📺"}]

# --- YouTube OAuth ---
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID must be your NUMERIC user ID (not @username)
# Get it by messaging @userinfobot on Telegram → it replies with your ID
TELEGRAM_CHAT_ID=123456789

# --- Hugging Face (for image generation) ---
HUGGINGFACE_API_TOKEN=your_huggingface_token

# --- Optional: OpenAI fallback ---
OPENAI_API_KEY=

# --- App ---
ENV=production   # development | production
LOG_LEVEL=INFO
OUTPUT_DIR=./output
ASSETS_DIR=./assets

# --- Railway Deployment ---
# PORT is automatically injected by Railway — do not set manually
# PORT=8000

# Base64-encoded secret files (Railway can't mount files like docker-compose)
# Encode locally: base64 -i client_secret.json | tr -d '\n'
YOUTUBE_CLIENT_SECRET_B64=

# Encode locally: base64 -i .youtube_token.pkl | tr -d '\n'
# (generate .youtube_token.pkl first by running locally with YouTube OAuth)
YOUTUBE_TOKEN_B64=

# Railway Volume: mount a volume at /app/data for SQLite persistence
# Set in Railway dashboard → your service → Volumes → Mount path: /app/data
