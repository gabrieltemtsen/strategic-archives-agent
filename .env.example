# =============================================
# STRATEGIC ARCHIVES AGENT - ENV CONFIG
# =============================================

# --- Google / Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID must be your NUMERIC user ID — get it from @userinfobot
TELEGRAM_CHAT_ID=123456789

# --- Hugging Face ---
HUGGINGFACE_API_TOKEN=your_huggingface_token

# --- Channels ---
# All 4 channels defined here. No code changes needed to add/remove channels.
# youtube_id: YouTube Studio → Settings → Advanced settings → Channel ID
# upload_times: list of 3 daily slots in WAT (Africa/Lagos) — morning / afternoon / evening
CHANNELS=[{"key":"kids_universe","name":"KidsUniverseFirst","youtube_id":"UCVDXMW5JbIl8_FoTOkmCR-g","niche":"kids content ONLY - fun educational stories, animal fun facts, nursery rhymes, simple science experiments, and bedtime stories for children aged 3-10. Warm, joyful, age-appropriate tone. NO adult content, NO violence, NO scary themes.","upload_times":["08:00","14:00","20:00"],"made_for_kids":true,"emoji":"\ud83d\udc76","languages":["en","yo","ha"]},{"key":"strategic_archives","name":"strategicarchives1","youtube_id":"UC7alY2zHeywQdMFMv6yY7Tg","niche":"current wars and geopolitical conflicts - breaking down ONGOING and RECENT conflicts: Russia-Ukraine war, Middle East conflicts, Sudan civil war, Taiwan tensions, NATO vs Russia, global sanctions, proxy wars, political controversies, power shifts and emerging threats shaping the world RIGHT NOW. Dramatic, journalistic, documentary style.","upload_times":["08:00","14:00","20:00"],"made_for_kids":false,"emoji":"\u2694\ufe0f","languages":["en"]},{"key":"stories_tales","name":"yt-storiesandtales","youtube_id":"UCXxVo39aLJupyC5UmTAAD1w","niche":"scary stories and creepy tales - spine-chilling horror stories, eerie urban legends, shocking true crime, mysterious disappearances, and supernatural tales that keep you up at night.","upload_times":["08:00","14:00","20:00"],"made_for_kids":false,"emoji":"\ud83d\udc7b","languages":["en"]},{"key":"gabe_dev_codes","name":"gabedevcodes","youtube_id":"UCfX3YMbTv6lWaU983F-GCDA","niche":"coding tutorials and AI development - practical programming guides, how to build and leverage AI tools, developer tips, and real projects that generate income online.","upload_times":["08:00","14:00","20:00"],"made_for_kids":false,"emoji":"\ud83d\udcbb","languages":["en"]}]

# --- YouTube OAuth Client Secret ---
# Download from Google Cloud Console → APIs & Services → Credentials
# Encode: base64 -i client_secret.json | tr -d '\n'
YOUTUBE_CLIENT_SECRET_B64=

# --- Per-Channel YouTube Tokens (REQUIRED — one per channel) ---
# Generate with: python scripts/auth_channel.py --channel <key>
# IMPORTANT: Switch to the correct channel in YouTube Studio BEFORE running!
# Encode: base64 -i .youtube_token_kids_universe.pkl | tr -d '\n'

YOUTUBE_TOKEN_B64_KIDS_UNIVERSE=
YOUTUBE_TOKEN_B64_STRATEGIC_ARCHIVES=
YOUTUBE_TOKEN_B64_STORIES_TALES=
YOUTUBE_TOKEN_B64_GABE_DEV_CODES=

# Legacy single-channel fallback (uploads to default channel — avoid using)
# YOUTUBE_TOKEN_B64=

# --- Higgsfield (Movie Engine) ---
# Get from: https://cloud.higgsfield.ai/settings/api-keys
HIGGSFIELD_KEY_ID=ea73bd62-0644-4600-a7a4-17ab25999916
HIGGSFIELD_SECRET=your_higgsfield_secret_here

# --- Railway Public URL (required for Higgsfield image fetching) ---
# Set this to your Railway deployment URL so generated images are publicly accessible
# Format: https://your-app-name.up.railway.app  (no trailing slash)
RAILWAY_PUBLIC_URL=https://your-app.up.railway.app

# --- imgbb (optional fallback for image hosting) ---
# Only needed if RAILWAY_PUBLIC_URL is not set
# Get free API key at: https://api.imgbb.com/
# IMGBB_API_KEY=

# --- App ---
LOG_LEVEL=INFO
OUTPUT_DIR=./output
ASSETS_DIR=./assets

# --- Railway ---
# PORT is auto-injected by Railway — do not set manually
# Railway Volume: mount at /app/data for SQLite (jobs.db)
